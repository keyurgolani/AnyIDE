# AnyIDE Environment Configuration
# All variables support both ANYIDE_* (recommended) and legacy HOSTBRIDGE_* prefixes.
# The ANYIDE_* variables take precedence over their HOSTBRIDGE_* equivalents.

# Required
ANYIDE_ADMIN_PASSWORD=changeme
# Legacy: ADMIN_PASSWORD=changeme

# Workspace
ANYIDE_WORKSPACE_BASE_DIR=/workspace
ANYIDE_HOST_WORKSPACE_DIR=./workspace
# Legacy: WORKSPACE_BASE_DIR=/workspace, HOST_WORKSPACE_DIR=./workspace

# Optional
ANYIDE_PORT=8080
# Legacy: HOSTBRIDGE_PORT=8080

ANYIDE_AUDIT_RETENTION_DAYS=30
# Legacy: AUDIT_RETENTION_DAYS=30

ANYIDE_LOG_LEVEL=INFO
# Legacy: LOG_LEVEL=INFO

ANYIDE_HITL_TTL_SECONDS=300
# Legacy: HITL_TTL_SECONDS=300

ANYIDE_MODULES=all
# Examples: all,-docker,-http or fs,workspace,shell,git,memory,plan

ANYIDE_SECRETS_FILE_PATH=./secrets.env
# Legacy: SECRETS_FILE_PATH=./secrets.env

ANYIDE_CONFIG_FILE=./config.yaml
# Legacy: CONFIG_FILE=./config.yaml
